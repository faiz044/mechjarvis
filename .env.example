ANTHROPIC_API_KEY=your-anthropic-key
FISH_API_KEY=your-fish-audio-key
USER_NAME=YourName

# CAD Platform Paths (adjust based on your installation)
SOLIDWORKS_PATH=C:\Program Files\SolidWorks
FREECAD_PATH=C:\Program Files\FreeCAD
FUSION360_PATH=C:\Users\YourName\AppData\Local\Autodesk\webdeploy\production

# Analysis Settings
FEA_ENABLED=true
TOLERANCE_ANALYSIS=true
COST_ESTIMATION=true